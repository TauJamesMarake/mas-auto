# ── .env.example ──────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env — only commit this file.

# MySQL (from cPanel → MySQL Databases)
DB_HOST=localhost
DB_NAME=
DB_USER=
DB_PASS=

# Resend SMTP (from resend.com → API Keys)
RESEND_API_KEY=

# Email addresses
FROM_EMAIL=bookings@masauto.co.za
FROM_NAME=MAS Auto
ADMIN_EMAIL=

# Site
SITE_URL=https://masauto.co.za
APP_ENV=production
